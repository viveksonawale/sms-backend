# ─────────────────────────────────────────────────────────────────────────────
# Society Management System — Environment Variables
# Copy this file to .env and fill in values for your environment.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/sms_db
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# JWT — minimum 32 characters (256-bit) required for HS256
JWT_SECRET=replace-this-with-a-256-bit-random-secret-key-for-production

# Admin credentials (used by seeder on first startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=YourStrongPassword@123
